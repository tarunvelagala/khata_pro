#!/usr/bin/env bash

# This hook ensures that the code reviewer and UI tester agents run before every commit,
# which guarantees our "unbreakable commits" rule.

echo ""
echo "====================================="
echo "🤖 Triggering Autonomous Agents..."
echo "====================================="
echo ""

echo "🕵️  [Code Reviewer Agent]: Running Effective Dart & Lint Checks..."
flutter analyze
ANALYZE_RESULT=$?

if [ $ANALYZE_RESULT -ne 0 ]; then
  echo ""
  echo "❌ [Code Reviewer Agent]: Failed! Please fix the lints/formatting issues above before committing."
  echo "====================================="
  exit 1
fi
echo "✅ [Code Reviewer Agent]: Passed elegantly!"
echo ""


echo "🧪 [UI Tester Agent]: Executing Widget & Golden Tests..."
flutter test
TEST_RESULT=$?

if [ $TEST_RESULT -ne 0 ]; then
  echo ""
  echo "❌ [UI Tester Agent]: Failed! Tests must pass to guarantee unbreakable commit."
  echo "====================================="
  exit 1
fi
echo "✅ [UI Tester Agent]: Passed! Your layout and capabilities verify properly."
echo ""

echo "📊 [SDE Reviewer Agent]: Collecting Coverage Metrics..."
flutter test --coverage > /dev/null 2>&1
COVERAGE_RESULT=$?

if [ $COVERAGE_RESULT -ne 0 ]; then
  echo ""
  echo "⚠️  [SDE Reviewer Agent]: Coverage collection was skipped or failed."
  echo "   (This is informational; commits can proceed if tests passed above.)"
  echo ""
else
  echo "✅ [SDE Reviewer Agent]: Coverage metrics collected → coverage/lcov.info"
  echo "   Check coverage with: open coverage/index.html"
  echo ""
fi

echo "🎉 All Agents approved this commit!"
echo ""
echo "💡 Tip: For detailed Senior SDE code review (coverage 85%+, Effective Dart,"
echo "   Riverpod patterns), use the Flutter SDE Reviewer agent in VS Code Chat:"
echo "   - Invoke agent picker (Cmd+I)"
echo "   - Select 'Flutter SDE Reviewer'"
echo "   - Provide file paths or commit hash for detailed analysis"
echo "====================================="

exit 0
